<Window x:Class="MVVM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MVVM"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <StackPanel>
                <Slider  x:Name="slider"   Margin="5" Height="30" ValueChanged="Slider_ValueChanged"/>
                <TextBox x:Name="textbox1" Margin="5" Height="30" TextChanged="textbox1_TextChanged"/>
            </StackPanel>
            <StackPanel
                Margin="0 20 0 0"
                Grid.Row="1">
                <Slider  x:Name="slider2" Margin="5" Height="30" ValueChanged="Slider_ValueChanged"/>
                <TextBox Text="{Binding ElementName=slider2, Path=Value, Mode=Default}"/>
            </StackPanel>
            <!--注意一下绑定的几种mode吧，没什么营养-->
        </Grid>

        <Grid Grid.Row="1" Margin="0 50 0 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal">
                <TextBox Text="{Binding Name}" Height="30" Width="200" Margin="5"/>
                <TextBox Text="{Binding Title}" Height="30" Width="200" Margin="5"/>
                <Button Command="{Binding ShowCommand}" Height="30" Width="30" Content="here" Margin="5"/>
            </StackPanel>


        </Grid>
        
        
        
        
        
        
        
    </Grid>
</Window>

    
